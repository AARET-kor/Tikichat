# ═══════════════════════════════════════════════════════════════
# LIBHIB TikiChat — 서버 환경변수 예시
# ⚠️  VITE_ 접두사 절대 사용 금지 (클라이언트 노출 방지)
# ⚠️  실제 .env 파일은 절대 git commit 금지
# ═══════════════════════════════════════════════════════════════

# ── 서버 ─────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── 클리닉 식별 (Railway 서비스당 1 클리닉) ─────────────────
CLINIC_ID=libhib-gangnam

# ── Anthropic Claude ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
# 모델 override (기본값 사용 권장)
# MODEL_HAIKU=claude-haiku-4-5-20251001
# MODEL_SONNET=claude-sonnet-4-6-20260217

# ── OpenAI (선택 — 벡터 임베딩 하이브리드 RAG용) ────────────
# OPENAI_API_KEY=sk-...

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...               # 클라이언트용 (프론트엔드 .env.local에 VITE_ 접두사로 따로 관리)
SUPABASE_SERVICE_ROLE_KEY=eyJ...       # 서버 전용 (RLS bypass, 절대 클라이언트에 노출 금지)

# ── Redis (BullMQ 큐 — Railway Redis 플러그인 자동 주입) ─────
REDIS_URL=redis://default:password@hostname:6379

# ── Meta (Facebook / Instagram / WhatsApp) ───────────────────
META_APP_SECRET=abc123...              # X-Hub-Signature-256 HMAC 검증용
META_VERIFY_TOKEN=my-verify-token-123  # GET 구독 인증용
META_ACCESS_TOKEN=EAAxxxxx...          # Graph API 발신 토큰
META_PHONE_NUMBER_ID=123456789         # WhatsApp 발신 번호 ID
META_PAGE_ID=987654321                 # Instagram 연결 페이지 ID

# ── Solapi (카카오 알림톡 / 친구톡) ─────────────────────────
SOLAPI_API_KEY=NCS...
SOLAPI_API_SECRET=VKCS...
SOLAPI_SENDER=0212345678               # 발신 번호
SOLAPI_PF_ID=KA01PF...                 # 카카오 플러스친구 ID
